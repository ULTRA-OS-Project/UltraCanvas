<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for Hardened Runtime (needed for notarization) -->
    <key>com.apple.security.cs.allow-jit</key>
    <false/>

    <!-- If your app loads dylibs at runtime -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- If you use Cairo/Pango/Homebrew dylibs that aren't Apple-signed -->
    <!-- Set this to true ONLY if signing all dylibs doesn't fix the crash -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <false/>
</dict>
</plist>
